# =============================================================================
# DEVELOPMENT ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.development and fill in your actual values
# This file contains all environment variables for both frontend and backend services
#
# QUICK SETUP FOR DEVELOPMENT:
# 1. cp .env.development.example .env.development
# 2. Update email credentials (GMAIL_USER, GMAIL_APP_PASSWORD, FROM_EMAIL, TO_EMAIL)
# 3. Run: docker compose -f docker-compose.dev.yml --env-file .env.development up --build
# 4. Access: http://localhost (NGINX proxy with auth bypass)

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# React/Vite Development Settings (NGINX Proxy Setup)
NODE_ENV=development
VITE_API_URL=http://localhost
VITE_BACKEND_URL=http://localhost

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
# Server Settings
PORT=3001
HOST=0.0.0.0
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Database
DATABASE_PATH=/app/data/portfolio.db

# =============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# =============================================================================
# Gmail SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Gmail Credentials (REQUIRED - Replace with your actual values)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Email Recipients (REQUIRED - Replace with your actual values)
FROM_EMAIL=your-email@gmail.com
TO_EMAIL=your-email@gmail.com
ADMIN_EMAIL=your-email@gmail.com
MESSAGE_ID_DOMAIN=localhost

# =============================================================================
# GMAIL API CONFIGURATION (Optional - for conversation threading)
# =============================================================================
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost/api/admin/gmail/callback
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_ACCESS_TOKEN=your-gmail-access-token

# =============================================================================
# SECURITY & AUTHENTICATION (Development - Safe defaults provided)
# =============================================================================
# JWT Configuration (Development secret - CHANGE FOR PRODUCTION)
JWT_SECRET=development-jwt-secret-key-not-for-production-use-only

# Admin Authentication (Development credentials - CHANGE FOR PRODUCTION)
ADMIN_TOKEN=dev-admin-token-123
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Password Hashing
BCRYPT_ROUNDS=10

# =============================================================================
# RATE LIMITING (Development - Relaxed limits)
# =============================================================================
# General Rate Limiting (15 minutes window)
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Contact Form Rate Limiting (1 hour window)
CONTACT_RATE_LIMIT_WINDOW=3600000
CONTACT_RATE_LIMIT_MAX=5

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=debug
LOG_FILE=/app/logs/portfolio.log

# =============================================================================
# MESSAGE VALIDATION
# =============================================================================
MAX_MESSAGE_LENGTH=5000
MIN_MESSAGE_LENGTH=10

# =============================================================================
# DOCKER NETWORK CONFIGURATION (Do not change unless needed)
# =============================================================================
# Internal Docker Network IPs for NGINX + Frontend + Backend
FRONTEND_IP=172.20.0.20
BACKEND_IP=172.20.0.30
NETWORK_SUBNET=172.20.0.0/16
NETWORK_GATEWAY=172.20.0.1
